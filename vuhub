rs.RenderStepped:Connect(function()
    for _, p in pairs(game.Players:GetPlayers()) do
        if settings.HitboxAll or settings.HitboxTeam then 
            applyHitboxReal(p, settings.HitboxTeam) 
        else 
            resetHitboxReal(p) 
        end
        if settings.ESPAll or settings.ESPTeam then 
            applyESP(p, settings.ESPTeam) 
        else 
            resetESP(p) 
        end
    end
end)

